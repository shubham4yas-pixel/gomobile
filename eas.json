{
  "cli": {
    "version": ">= 20.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SOCKET_URL": "https://puny-clocks-sleep.loca.lt"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SOCKET_URL": "https://puny-clocks-sleep.loca.lt"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview-rider": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "rider"
      }
    },
    "preview-driver": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "driver"
      }
    },
    "production": {
      "autoIncrement": true
    },
    "production-rider": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "rider"
      }
    },
    "production-driver": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "driver"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
